{# _includes/layouts/base.njk #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }}{% else %}Quanah Parker Trail{% endif %}</title> {# Added page title fallback #}

    <link rel="stylesheet" href="{{ '/css/style.css' | url }}">

    {# Google Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Rock+Salt&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://use.typekit.net/qjy2ghh.css">

    {# Leaflet CSS #}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
     integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
     crossorigin=""/>
    <link rel="stylesheet" href="https://unpkg.com/leaflet-gesture-handling@1.2.2/dist/leaflet-gesture-handling.min.css"
     type="text/css">

</head>
<body class="{{ 'page-home' if page.url == '/' }} {{ bodyClass if bodyClass else '' }}"> {# Added fallback for bodyClass #}

    {% include "partials/header.njk" %}

    <main>
        {{ content | safe }}
    </main>

    {% include "partials/footer.njk" %}

    {# Conditionally add button and popup only on county pages #}
    {% if page.url != '/' and countyName %}
      <button type="button" class="map-fab" id="toggle-mini-map-btn" title="Show County Location Overview">
          <svg fill="#fff" version="1.1" viewBox="0 0 94 128" xmlns="http://www.w3.org/2000/svg"><path d="m46.977 126.64c-0.28303-0.6875-6.1631-6.4377-10.374-11.663-24.947-33.122-52.761-63.898-20.283-101.3 14.381-13.894 32.113-14.686 50.343-8.2101 51.33 29.702 14.166 78.155-10.235 110.01l-9.4501 11.163zm15.44-50.771c34.237-24.485 7.768-71.633-29.848-55.959-10.984 5.8569-16.434 16.048-16.625 28.068-0.5245 11.693 5.6854 21.471 15.526 27.461 7.0555 3.8401 10.157 4.5337 18.146 4.0577 5.1776-0.30852 8.1611-1.1538 12.801-3.6271z" fill-opacity=".98824"/><path transform="matrix(.87829 0 0 1.0519 .55474 -6.9953)" d="m41.682 89.891a51.223 41.754 0 1 1 1.2766 0.20809" fill="#fff" fill-opacity=".98824"/><path transform="translate(.64535)" d="m43.631 69.129a26.011 20.991 0 1 1 0.64826 0.10461" fill-opacity="0" opacity=".34016"/><path transform="translate(.64535)" d="m31.892 114.28a16.656 11.75 0 1 1 0.41511 0.0586" fill-opacity="0"/><path transform="matrix(.9702 0 0 1.0272 -4.0588 -5.7504)" d="m45.521 84.824a34.453 33.54 0 1 1 0.85866 0.16716" fill="#004E89"/><path transform="matrix(.6463 0 0 .61681 5.1261 4.9014)" d="m57.079 104.61a34.203 36.623 0 1 1 0.85244 0.18252" fill="#fff"/></svg>
      </button>
      <div class="mini-map-popup" id="mini-map-popup-container">
          {% include "partials/county-map-link.njk" %}
      </div>
      <div id="mini-map-tooltip" class="map-tooltip-ui"></div>
    {% endif %}

    <div class="modal-overlay" id="greeting-modal-overlay">
      <div class="modal-content" id="greeting-modal-content" role="dialog" aria-labelledby="greeting-modal-title" aria-modal="true">
        <button class="modal-close-btn" id="greeting-modal-close-btn" aria-label="Close greeting message">&times;</button>
        <img src="{{ '/img/arrow-logo.png' | url }}"
             alt="Quanah Parker Trail Arrow graphic"
             class="modal-greeting-image">
        <h2 id="greeting-modal-title">Welcome to the Quanah Parker Trail!</h2>
        <p>
          Explore the historical arrow markers commemorating Quanah Parker and the Comanche people across the Texas Plains Trail Region. Use the map on the homepage or navigate via the menu to learn more about this effort.
        </p>
      </div>
    </div>

    {# Leaflet JS Libraries - Moved here for better performance #}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
     integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
     crossorigin=""></script>
    <script src="https://unpkg.com/leaflet-gesture-handling@1.2.2/dist/leaflet-gesture-handling.min.js"></script>

    {# Inline script to define global siteBasePath - MUST be before any script that uses it #}
    <script>
      window.siteBasePath = "{{ '/' | url }}";
      // console.log('Site Base Path for JS:', window.siteBasePath); // For debugging
    </script>

    {# Links to your separated JavaScript files #}
    <script src="{{ '/js/greeting-modal.js' | url }}"></script>
    <script src="{{ '/js/mobile-menu.js' | url }}"></script>
    {# Load mini-map script only if not on homepage AND countyName exists (same condition as FAB) #}
    {% if page.url != '/counties/' and countyName %}
    <script src="{{ '/js/mini-map-popup.js' | url }}"></script>
    {% endif %}
    <script src="{{ '/js/collapsible-toc.js' | url }}"></script>
    <script src="{{ '/js/footer-scripts.js' | url }}"></script>

</body>
</html>